# Database URL (SQLite for dev)
DATABASE_URL="file:./dev.db"

# For PostgreSQL production:
# DATABASE_URL="postgresql://user:password@host:5432/proto_fm?schema=public"

# NextAuth (if you add authentication later)
# NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
# NEXTAUTH_URL="http://localhost:3000"

# Formspree (optional — for engage form in production instead of in-memory)
# FORMSPREE_ENDPOINT="https://formspree.io/f/your-id"

# Resend (optional — for email forwarding of engage form submissions)
# Get your API key at https://resend.com (free tier: 100 emails/day)
# RESEND_API_KEY="re_xxxxxxxx"
# ENGINEER_EMAIL="mohammed@your-domain.com"
# FROM_EMAIL="portfolio@your-domain.com"

# Sentry (optional — for error tracking)
# Get your DSN at https://sentry.io (free tier: 5,000 errors/month)
# SENTRY_DSN="https://xxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX"

# Vercel Analytics — automatically enabled when deployed on Vercel
# No env var needed — just @vercel/analytics package
