// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== Engage form submissions (Phase 2: replaces in-memory array) =====
model Submission {
  id        String   @id @default(cuid())
  path      String   // review | consult | build | refer
  name      String
  email     String
  fields    String   @default("{}") // JSON string of extra fields
  ipHash    String?  // hashed IP for rate limiting (no raw IP stored)
  status    String   @default("new") // new | read | archived
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([status])
}
